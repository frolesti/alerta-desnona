# ═══════════════════════════════════════════════════════════════
# Configuració IA per normalitzar adreces
# ═══════════════════════════════════════════════════════════════
#
# GOOGLE GEMINI (GRATUÏT — recomanat)
# Clau gratuïta a: https://aistudio.google.com/apikey
#
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=AIza_LA_TEVA_CLAU_AQUI
#
# ───────────────────────────────────────────────────────────────
# ALTERNATIVES:
#
# OLLAMA (LOCAL, 100% GRATUÏT):
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.2
# OPENAI_API_KEY=ollama
#
# GROQ (CLOUD, GRATUÏT):
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY=gsk_...
#
# OPENAI (de pagament):
# AI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# ═══════════════════════════════════════════════════════════════
# Push Notifications (Web Push / VAPID)
# ═══════════════════════════════════════════════════════════════
#
# Genera les claus amb: npx web-push generate-vapid-keys
#
VAPID_PUBLIC_KEY=LA_TEVA_CLAU_PUBLICA_VAPID
VAPID_PRIVATE_KEY=LA_TEVA_CLAU_PRIVADA_VAPID
VAPID_EMAIL=mailto:el_teu_email@exemple.cat

